# ==========================================
# AlertApp API - Variables locales de ejemplo
# ==========================================
NODE_ENV=development
PORT=4000

# PostgreSQL local con PostGIS habilitado.
DATABASE_URL=postgresql://alertapp:alertapp_dev_password@localhost:5432/alertapp
DATABASE_SSL=false

# Frontend permitido para cookies y CORS.
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
APP_PUBLIC_URL=http://localhost:5173

# Secretos: reemplázalos por cadenas aleatorias largas antes de ejecutar.
JWT_ACCESS_SECRET=reemplazar_por_un_secreto_de_al_menos_32_caracteres
AUTH_TOKEN_PEPPER=reemplazar_por_otro_secreto_de_al_menos_32_caracteres
ACCESS_TOKEN_EXPIRES_IN_MINUTES=15
REFRESH_TOKEN_EXPIRES_DAYS=7
COOKIE_SECURE=false

# Correo: console solo en desarrollo. Producción debe usar resend.
MAIL_PROVIDER=console
MAIL_FROM=AlertApp <no-reply@example.com>
RESEND_API_KEY=
EXPOSE_DEV_TOKENS=true

# Seed local. Nunca mantener usuarios demo activos en producción.
SEED_DEMO_DATA=true
SEED_CITIZEN_EMAIL=ciudadano.demo@alertapp.local
SEED_CITIZEN_PASSWORD=CiudadanoDemo2026!
SEED_AGENT_EMAIL=agente.demo@alertapp.local
SEED_AGENT_PASSWORD=AgenteDemo2026!
SEED_ADMIN_EMAIL=admin.demo@alertapp.local
SEED_ADMIN_PASSWORD=AdminDemo2026!

# Administrador inicial real: usar solo al aprovisionar producción y después retirar.
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# Cookies entre frontend y API. Usa none solo con HTTPS y dominios diferentes.
COOKIE_SAME_SITE=lax

# Evidencias: local solo para desarrollo; Cloudinary obligatorio en producción.
EVIDENCE_STORAGE_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
LOCAL_UPLOAD_DIR=uploads/evidencias
MAX_EVIDENCE_SIZE_MB=5
MAX_EVIDENCES_PER_REPORT=3
